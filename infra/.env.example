# ASHA-AI · production env file template
# ======================================
# Copy to .env and fill with real secrets before `docker compose up`.
# NEVER commit the real .env. The .env file is gitignored at the repo root.

# ──────────── Postgres ────────────
POSTGRES_USER=asha
POSTGRES_PASSWORD=                   # required — generate via `openssl rand -base64 32`
POSTGRES_DB=asha_ai

# ──────────── MinIO ────────────
MINIO_ROOT_USER=asha-admin
MINIO_ROOT_PASSWORD=                 # required — generate via `openssl rand -base64 32`
MINIO_BUCKET=asha-uploads

# ──────────── JWT (Tier 6.6 Phase A) ────────────
JWT_SECRET=                          # required — generate via `openssl rand -hex 64`

# ──────────── External providers ────────────
GEMINI_API_KEY=                      # Plan 3.0-4.0 cloud LLM
TOGETHER_API_KEY=                    # Tier 6.5 Phase H · Llama 3.3 70B Q4 hosting
LLM_PROVIDER=gemini25-flash          # gemini25-flash | llama33-together
BHASHINI_API_KEY=                    # Plan 3.0 voice (Hindi/Kannada STT + NMT + TTS)
MSG91_AUTH_KEY=                      # Tier 6.6 Phase A · phone OTP
MSG91_OTP_TEMPLATE_ID=
RAZORPAY_KEY_ID=                     # Tier 6.6 Phase H · Second Opinion Bridge payments
RAZORPAY_KEY_SECRET=
RAZORPAY_LIVE=false                  # MUST stay false until KYC clears
FCM_SERVICE_ACCOUNT_JSON=            # Tier 6.4+6.6 · base64-encoded JSON service-account key
WHATSAPP_PHONE_ID=                   # Tier 6.6 Phase H · WhatsApp Business outbound
WHATSAPP_ACCESS_TOKEN=
ABDM_BASE_URL=https://dev.abdm.gov.in    # sandbox; flip to prod URL post-NHA approval
ABDM_CLIENT_ID=                      # Tier 6.6 Phase C · ABDM HFR sandbox
ABDM_CLIENT_SECRET=
ABLY_API_KEY=                        # Tier 6.4 · realtime risk-CRITICAL channel

# ──────────── Tier 6.5 brain-stack feature flags (off by default) ────────────
# Flip each ON only after that swap's eval gate per PROMPTS_PLAN_6.5.md passes.
STT_BACKEND=whisper-base             # Phase B target: whisper-turbo
RAG_BACKEND=chroma_legacy            # Phase D target: qdrant_hybrid
RAG_RERANK=off                       # Phase E target: on
RAG_HYDE=off                         # Phase F target: on
PIPELINE=legacy                      # Phase G target: langgraph
VISION_TRIAGE=off                    # Phase I target: on (post-MBBS sign-off)

# ──────────── Observability (Tier 6.6 Phase F) ────────────
SENTRY_DSN=                          # Sentry SDK · auto PHI-scrub configured at backend
SENTRY_ENV=production
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=              # required if running `--profile observability`
GRAFANA_HOST=grafana.asha-ai.in

# ──────────── Hosts (Tier 6.6 Phase D · Traefik) ────────────
API_HOST=api.asha-ai.in
FLOWER_HOST=flower.asha-ai.in
TRAEFIK_HOST=traefik.asha-ai.in
LETSENCRYPT_EMAIL=                   # required for Let's Encrypt ACME registration
TRAEFIK_AUTH=                        # htpasswd format: `htpasswd -nb admin <password>`
FLOWER_USER=admin
FLOWER_PASSWORD=                     # required
