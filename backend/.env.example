# ─── Plan 1.0 (CORS) ────────────────────────────────────────────────────
# Comma-separated list of allowed CORS origins (production)
# Frontend deploy origin will be set here by Role A once their Vercel URL is final
FRONTEND_ORIGIN=https://asha-ai.vercel.app

# Regex pattern for Vercel preview deploys (per-PR previews)
VERCEL_PREVIEW_ORIGIN_REGEX=^https://.*\.vercel\.app$

# Port (Render injects this automatically; default 8000 for local)
PORT=8000

# ─── Plan 2.0 (Supabase auth + persistence) ─────────────────────────────
# Provision Supabase project (Mumbai region) and apply
# db/migrations/001_plan2_schema.sql before setting these.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# ─── Plan 2.0 (rate limiting) ───────────────────────────────────────────
# Default is 10/minute per user. Bump in dev to avoid blocking yourself.
RATE_LIMIT_TRIAGE=10/minute

# ─── Plan 2.0 (XGBoost model path) ──────────────────────────────────────
# Defaults to D:\hack\ml\models (Role C ships xgboost_v1.pkl +
# xgboost_v1_metadata.json there). Override for Docker/Render where the
# path may differ.
# MODEL_DIR=/app/ml/models

# ─── Plan 2.0 (Gemini — Role C wires it in, Role B reads the key) ───────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ─── Plan 3.0 (Bhashini voice pipeline) ─────────────────────────────────
# Free PoC tier: https://bhashini.gov.in → developer signup.
BHASHINI_API_KEY=
BHASHINI_BASE=https://meity-auth.ulcacontrib.org

# ─── Plan 3.0 (LLM provider — Gemini cloud OR Ollama edge) ──────────────
# Role C's LLMProvider abstraction reads this. Set to "ollama" + run
# `ollama serve` locally to demo the unplug-the-wifi beat.
LLM_PROVIDER=gemini
OLLAMA_MODEL=gemma2:9b
OLLAMA_BASE=http://localhost:11434

# ─── Plan 3.0 (RAG embedder — Role C ships corpus.jsonl) ────────────────
# Default is BGE-M3 (1024-dim, matches db/migrations/002_plan3_rag.sql).
RAG_EMBED_MODEL=BAAI/bge-m3
